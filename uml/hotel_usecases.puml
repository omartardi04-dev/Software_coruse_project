skinparam UsecaseBackgroundColor #EAFAF1
skinparam UsecaseArrowColor #2C3E50

actor "Receptionist" as REC
actor "Payment Gateway" as PG
actor "Email Service" as ES

rectangle "Front-Desk Operations" {

  usecase "Check-in Guest" as UC_CI
  usecase "Verify Reservation" as UC_VERIF
  usecase "Assign / Reassign Room" as UC_ASSIGN
  usecase "Check-out Guest" as UC_CO
  usecase "Generate Invoice" as UC_INV
  usecase "Process On-site Payment" as UC_PAY

  usecase "Record Guest Information" as UC_RECORD
  usecase "Handle Special Requests" as UC_SPECIAL
  usecase "Early Check-in" as UC_EARLY
  usecase "Late Check-out" as UC_LATE
  usecase "Send Confirmation Email" as UC_EMAIL


' ============================================================
' DIAGRAM 1 — Online Reservation (Guest-Facing)
' ============================================================

@startuml Diagram1_OnlineReservation
title Hotel Reservation System\n<b>Diagram 1: Online Reservation (Guest-Facing)</b>

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam ArrowColor #2C3E50
skinparam ActorBorderColor #2C3E50
skinparam ActorBackgroundColor #D6EAF8
skinparam UsecaseBorderColor #2874A6
skinparam UsecaseBackgroundColor #EBF5FB
skinparam UsecaseArrowColor #2C3E50

actor "Guest / Customer" as Guest
actor "Payment Gateway" as PG
actor "Email Service" as ES

rectangle "Online Reservation" {

  usecase "Register Account" as UC_REG
  usecase "Login" as UC_LOGIN
  usecase "Search Available Rooms" as UC_SEARCH
  usecase "View Room Details" as UC_VIEW
  usecase "Make Reservation" as UC_BOOK
  usecase "Apply Promo Code" as UC_PROMO
  usecase "Make Online Payment" as UC_PAY
  usecase "Send Confirmation Email" as UC_EMAIL
  usecase "Modify Reservation" as UC_MODIFY
  usecase "Cancel Reservation" as UC_CANCEL
  usecase "View Booking History" as UC_HISTORY
  usecase "Submit Review" as UC_REVIEW

}

' Guest interactions
Guest --> UC_REG
Guest --> UC_LOGIN
Guest --> UC_SEARCH
Guest --> UC_VIEW
Guest --> UC_BOOK
Guest --> UC_MODIFY
Guest --> UC_CANCEL
Guest --> UC_HISTORY
Guest --> UC_REVIEW

' Include relationships
UC_BOOK ..> UC_SEARCH    : <<include>>
UC_BOOK ..> UC_PAY       : <<include>>
UC_BOOK ..> UC_EMAIL     : <<include>>
UC_MODIFY ..> UC_LOGIN   : <<include>>
UC_CANCEL ..> UC_LOGIN   : <<include>>
UC_HISTORY ..> UC_LOGIN  : <<include>>

' Extend relationships
UC_PROMO ..> UC_BOOK     : <<extend>>

' External systems
UC_PAY   --> PG
UC_EMAIL --> ES

@enduml


' ============================================================
' DIAGRAM 2 — Front-Desk Operations
' ============================================================

@startuml Diagram2_FrontDesk
title Hotel Reservation System\n<b>Diagram 2: Front-Desk Operations</b>

left to right direction
skinparam actorStyle awesome
